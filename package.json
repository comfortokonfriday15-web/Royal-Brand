    "express": "^5.2.1",
    "framer-motion": "^12.35.2",
    "lucide-react": "^0.546.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.1",
    "tsx": "^4.22.3",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.28.0",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
